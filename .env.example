# This app now runs the full engine in-process (no more separate backend to
# point at) — see main.py. Copy this to .env and fill in real values.

SUPABASE_URL=
SUPABASE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Data-plane API key for /api/v1/verify — unset disables the check (dev mode).
API_KEY=

# Set on Render to point the browser at your local Docker API, e.g. an
# ngrok tunnel. Leave blank for same-origin.
EXTERNAL_API_URL=

# Admin dashboard super-admin login. ADMIN_SESSION_SECRET must be set for
# any admin session to verify — no fallback/default, a predictable secret
# would let anyone forge a session cookie.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Free key from https://www.opensanctions.org/api/ — PEP/sanctions/KYB
# screening returns risk_classification "UNAVAILABLE" without this set.
OPENSANCTIONS_API_KEY=
