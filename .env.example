# Admin dashboard runs the backend in-process (production/) — no separate
# server to point at. Copy this to .env and fill in real values.

SUPABASE_URL=
SUPABASE_KEY=

# Must be set for any admin session to verify — no fallback/default, a
# predictable secret would let anyone forge a session cookie.
ADMIN_SESSION_SECRET=

# Free key from https://www.opensanctions.org/api/ — PEP/sanctions/KYB
# screening returns risk_classification "UNAVAILABLE" without this set.
OPENSANCTIONS_API_KEY=

# Base URL of the (separate) client capture app, for the "Generate Link"
# page's applicant links, e.g. https://capture.example.com. Optional —
# links just come back without a URL if unset.
CAPTURE_BASE_URL=
